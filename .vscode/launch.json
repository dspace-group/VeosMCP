{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch MCP server",
            "type": "debugpy",
            "request": "launch",
            "module": "veos_mcp.server",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "args": [
                "--veos-version",
                "26-A"
            ]
        }
    ]
}